{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "needs_human",
        "blocked",
        "failed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "issue_comment": {
      "type": "string",
      "minLength": 1
    },
    "branch": {
      "type": [
        "string",
        "null"
      ]
    },
    "commit": {
      "type": [
        "string",
        "null"
      ]
    },
    "pr_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "needs_follow_up": {
      "type": "boolean"
    }
  },
  "required": [
    "status",
    "summary",
    "issue_comment",
    "branch",
    "commit",
    "pr_url",
    "validation",
    "needs_follow_up"
  ]
}
